{
  "mcpServers": {
    "jobseeking-premium": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/premium-server.js"],
      "env": {
        "API_ENDPOINT": "https://api.jobseeking.ai",
        "API_KEY": "${user_config.api_key}",
        "PLUGIN_VERSION": "1.0.0"
      }
    },
    "job-boards": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/job-board-server.py"],
      "env": {
        "API_KEY": "${user_config.api_key}",
        "LINKEDIN_API_KEY": "${LINKEDIN_API_KEY}",
        "INDEED_API_KEY": "${INDEED_API_KEY}",
        "CACHE_DIR": "${CLAUDE_PLUGIN_DATA}/cache"
      }
    },
    "salary-research": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/salary-server.js"],
      "env": {
        "API_KEY": "${user_config.api_key}",
        "GLASSDOOR_API_KEY": "${GLASSDOOR_API_KEY}",
        "LEVELS_API_KEY": "${LEVELS_API_KEY}",
        "DATA_DIR": "${CLAUDE_PLUGIN_DATA}/salary-data"
      }
    }
  }
}